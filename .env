# =============================================
# Environment Variables — YouTube Summarizer
# =============================================
# Copy this file to .env and fill in your keys
# cp .env.example .env

# REQUIRED: Get your free Gemini API key at:
# https://aistudio.google.com/app/apikey
GROQ_API_KEY=---your key---
# 

# 


# OPTIONAL: YouTube Data API v3 key for fetching video title
# Without this, video title will show as "YouTube Video"
# Get it at: https://console.cloud.google.com/ → Enable "YouTube Data API v3"
YOUTUBE_API_KEY=your_youtube_data_api_key_here
